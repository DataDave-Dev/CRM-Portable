<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>DashboardView</class>
 <widget class="QWidget" name="DashboardView">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>980</width>
    <height>720</height>
   </rect>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* === DASHBOARD GENERAL === */
#DashboardView {
    background-color: #f0f2f5;
}

/* === HEADER ROW === */
#lblSeccionKPIs, #lblSeccionTablas {
    color: #1a1a2e;
    font-size: 16px;
    font-weight: bold;
}

/* === KPI CARDS === */
#cardContactos, #cardEmpresas, #cardOportunidades,
#cardPipeline, #cardConversion, #cardActividades {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    min-height: 110px;
    max-height: 130px;
}
#cardContactos:hover, #cardEmpresas:hover, #cardOportunidades:hover,
#cardPipeline:hover, #cardConversion:hover, #cardActividades:hover {
    border: 1px solid #4a90d9;
}

#lblContactosTitle, #lblEmpresasTitle, #lblOportunidadesTitle,
#lblPipelineTitle, #lblConversionTitle, #lblActividadesTitle {
    color: #7f8c9b;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
}
#lblContactosValue, #lblEmpresasValue, #lblOportunidadesValue,
#lblPipelineValue, #lblConversionValue, #lblActividadesValue {
    color: #1a1a2e;
    font-size: 30px;
    font-weight: bold;
}
#lblContactosDesc, #lblEmpresasDesc, #lblOportunidadesDesc,
#lblPipelineDesc, #lblConversionDesc, #lblActividadesDesc {
    color: #a0aec0;
    font-size: 11px;
}
#lblContactosIcon, #lblEmpresasIcon, #lblOportunidadesIcon,
#lblPipelineIcon, #lblConversionIcon, #lblActividadesIcon {
    color: #4a90d9;
    font-size: 20px;
}

/* === PANELES DE GRAFICAS === */
#panelChartPipeline, #panelChartOportunidades {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
}
#lblChartPipelineTitle, #lblChartOportunidadesTitle {
    color: #1a1a2e;
    font-size: 14px;
    font-weight: bold;
    padding: 4px 0px;
}
#lblSeccionGraficas {
    color: #1a1a2e;
    font-size: 16px;
    font-weight: bold;
}

/* === TABLAS === */
#panelActividades, #panelRecordatorios {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
}
#lblActividadesRecientes, #lblRecordatoriosProximos {
    color: #1a1a2e;
    font-size: 14px;
    font-weight: bold;
    padding: 4px 0px;
}
#tablaActividadesRecientes, #tablaRecordatoriosProximos {
    background-color: #ffffff;
    border: none;
    gridline-color: #f0f2f5;
    font-size: 13px;
    color: #2d3748;
    selection-background-color: #ebf4ff;
    selection-color: #1a1a2e;
    alternate-background-color: #f8fafc;
}
#tablaActividadesRecientes QHeaderView::section,
#tablaRecordatoriosProximos QHeaderView::section {
    background-color: #f8fafc;
    color: #7f8c9b;
    font-size: 11px;
    font-weight: 600;
    border: none;
    border-bottom: 1px solid #e2e8f0;
    padding: 6px 8px;
    text-transform: uppercase;
}

/* === REFRESH BUTTON === */
#btnRefresh {
    background-color: #4a90d9;
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    padding: 8px 20px;
    min-width: 120px;
}
#btnRefresh:hover {
    background-color: #357abd;
}
#btnRefresh:pressed {
    background-color: #2868a9;
}
   </string>
